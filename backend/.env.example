PORT=5000
MONGO_URI=mongodb://localhost:27017/alumni-network
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Admin Credentials (CHANGE BEFORE DEPLOYING) ─────────────────────────────
ADMIN_USERNAME=Admin
ADMIN_PASSWORD=Admin@123
ADMIN_EMAIL=admin@college.edu

# ── SMTP Email (for OTP + password reset) ───────────────────────────────────
# Use a Gmail App Password (not your main password)
# https://myaccount.google.com/apppasswords
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# ── Redis (optional — improves OTP reliability at scale) ────────────────────
# REDIS_URL=redis://localhost:6379
# or split:
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ── Cloudinary (highly recommended for production — avoids storing files in DB)
# Sign up free at https://cloudinary.com
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
